{
  "name": "github-stats-cards",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node dist/index.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app"
  },
  "dependencies": {
    "@hono/node-server": "^1",
    "@keyv/redis": "^5.1.6",
    "@t3-oss/env-core": "^0.13.10",
    "cacheable": "^2.3.2",
    "hono": "^4",
    "zod": "^3"
  },
  "devDependencies": {
    "@hono/vite-build": "^1",
    "@hono/vite-dev-server": "^0.25.0",
    "@types/node": "^24",
    "oxfmt": "^0.35.0",
    "oxlint": "^1",
    "typescript": "^5.8",
    "vite": "^8.0.0-beta",
    "vitest": "^3"
  },
  "volta": {
    "node": "24.13.1",
    "pnpm": "10.5.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
