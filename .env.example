# GitHub Personal Access Tokens (at least PAT_1 required)
PAT_1=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PAT_2=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server
PORT=3000

# Redis (optional — falls back to in-memory LRU if not set)
# REDIS_URL=redis://localhost:6379

# Cache
CACHE_TTL=14400

# Logging
LOG_LEVEL=info

# Metrics (optional — if not set, /metrics endpoint returns 404)
# METRICS_TOKEN=your-secret-token-here

# Sentry (optional — if not set, Sentry is disabled)
# SENTRY_DSN=https://key@o123.ingest.sentry.io/456
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=production
